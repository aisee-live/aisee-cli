  "components": {
    "schemas": {
      "CLIDeviceCodeRequest": {
        "properties": {
          "client_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Client Id",
            "default": "aisee-cli"
          }
        },
        "type": "object",
        "title": "CLIDeviceCodeRequest",
        "description": "CLI device code request model"
      },
      "CLIDeviceCodeResponse": {
        "properties": {
          "device_code": {
            "type": "string",
            "title": "Device Code"
          },
          "user_code": {
            "type": "string",
            "title": "User Code"
          },
          "verification_uri": {
            "type": "string",
            "title": "Verification Uri"
          },
          "verification_uri_complete": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Verification Uri Complete"
          },
          "token_url": {
            "type": "string",
            "title": "Token Url"
          },
          "token_refresh_url": {
            "type": "string",
            "title": "Token Refresh Url"
          },
          "access_token_url": {
            "type": "string",
            "title": "Access Token Url"
          },
          "expires_in": {
            "type": "integer",
            "title": "Expires In"
          },
          "interval": {
            "type": "integer",
            "title": "Interval"
          }
        },
        "type": "object",
        "required": [
          "device_code",
          "user_code",
          "verification_uri",
          "token_url",
          "token_refresh_url",
          "access_token_url",
          "expires_in",
          "interval"
        ],
        "title": "CLIDeviceCodeResponse",
        "description": "CLI device code response model"
      },
      "CLITokenRequest": {
        "properties": {
          "device_code": {
            "type": "string",
            "title": "Device Code"
          }
        },
        "type": "object",
        "required": [
          "device_code"
        ],
        "title": "CLITokenRequest",
        "description": "CLI token polling request model"
      },
      "CLIVerifyRequest": {
        "properties": {
          "user_code": {
            "type": "string",
            "title": "User Code"
          }
        },
        "type": "object",
        "required": [
          "user_code"
        ],
        "title": "CLIVerifyRequest",
        "description": "CLI verification request model (for user to enter code)"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "PasswordChange": {
        "properties": {
          "current_password": {
            "type": "string",
            "title": "Current Password"
          },
          "new_password": {
            "type": "string",
            "minLength": 8,
            "title": "New Password",
            "description": "New password must be at least 8 characters"
          }
        },
        "type": "object",
        "required": [
          "current_password",
          "new_password"
        ],
        "title": "PasswordChange",
        "description": "Password change request model"
